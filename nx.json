{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": [],
    "production": [
      "default",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/vitest.config.*",
      "!{projectRoot}/tsconfig.test.json"
    ]
  },
  "release": {
    "projects": ["sirannon-ts"],
    "projectsRelationship": "fixed",
    "releaseTagPattern": "v{version}",
    "version": {
      "conventionalCommits": false,
      "git": {
        "commit": true,
        "commitMessage": "chore(release): v{version}",
        "tag": false
      }
    },
    "changelog": {
      "workspaceChangelog": {
        "createRelease": "github"
      },
      "projectChangelogs": false,
      "git": {
        "commit": false,
        "tag": true
      }
    }
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "cache": true
    },
    "test": {
      "dependsOn": ["build"],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "lint": {
      "cache": false
    },
    "format": {
      "cache": false
    }
  }
}
