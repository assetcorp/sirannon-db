{
  "name": "@delali/sirannon-example-distributed-entitlements",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "certs": "tsx src/scripts/generate-certs.ts",
    "proxy:setup": "tsx src/scripts/setup-proxies.ts",
    "node": "tsx src/cluster-node.ts",
    "cluster:up": "docker compose up --build",
    "cluster:down": "docker compose down --volumes",
    "cluster:reset": "docker compose down --volumes && docker compose up --build",
    "app:dev": "vite dev --host 127.0.0.1",
    "dev": "concurrently -c cyan,magenta \"pnpm run cluster:up\" \"pnpm run app:dev\"",
    "build": "vite build",
    "serve": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@delali/sirannon-db": "workspace:*",
    "@grpc/grpc-js": "1.14.3",
    "@tanstack/react-router": "1.170.10",
    "@tanstack/react-start": "1.168.18",
    "better-sqlite3": "12.6.2",
    "etcd3": "1.1.2",
    "grpc-health-check": "2.1.0",
    "lucide-react": "1.17.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "selfsigned": "5.5.0",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.58.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.5.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "9.2.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "8.0.0"
  }
}
