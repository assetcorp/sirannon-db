{
  "name": "sirannon-ts",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/ts/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsup",
        "cwd": "packages/ts"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "check:bundle": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run check:bundle",
        "cwd": "packages/ts"
      },
      "dependsOn": ["build"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vitest run",
        "cwd": "packages/ts"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vitest run --coverage",
        "cwd": "packages/ts"
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vitest run --config vitest.e2e.config.ts",
        "cwd": "packages/ts"
      }
    },
    "test:soak": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vitest run --config vitest.soak.config.ts",
        "cwd": "packages/ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run lint",
        "cwd": "packages/ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run typecheck",
        "cwd": "packages/ts"
      }
    },
    "nx-release-publish": {
      "executor": "@nx/js:release-publish"
    }
  }
}
